# ─── GCP Project ──────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=nexum-assets
PUBSUB_TOPIC=media-events
PUBSUB_SUBSCRIPTION=media-worker-sub

# ─── Emulator Flags (set to true for local dev) ───────────────────
USE_GCS_EMULATOR=false
GCS_EMULATOR_HOST=http://localhost:4443

USE_PUBSUB_EMULATOR=false
PUBSUB_EMULATOR_HOST=localhost:8085

USE_FIRESTORE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8086

# ─── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_INGESTION_API_URL=http://localhost:8001
NEXT_PUBLIC_WORKER_API_URL=http://localhost:8002
