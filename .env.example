# NEXUM SHIELD — Environment Variables Example
# Copy this file to .env in both ingestion/ and worker/ directories for local testing.

# ─── Worker Settings (nexum-backend/worker/.env) ──────────────────
# Optional: MongoDB connection string (falls back to local JSON files if empty)
MONGODB_URI=

# Optional: Gemini API Key for Explainable AI (falls back to rule-based if empty)
GEMINI_API_KEY=AIzaSyBOfEkakz1lO-t-WvJUksWQ9pAUPAzsK0A

# ─── Ingestion Settings (nexum-backend/ingestion/.env) ────────────
# Where the Worker API is running locally
WORKER_URL=http://localhost:8002

# ─── Frontend Settings (nexum-frontend/.env.local) ────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
